{
  "expo": {
    "name": "Student Attendance App",
    "slug": "student-attendance-app",
    "version": "1.0.0",
    "scheme": "studentattendanceapp",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "icon": "./assets/images/Icon.png",
    "splash": {
     "image": "./assets/images/Icon.png",
  "imageWidth": 200,
  "resizeMode": "cover",
  "backgroundColor": "#f5e3d5"
    },
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.studentattendanceapp",
      "buildNumber": "1.0.0",
      "icon": "./assets/images/Icon.png",
      "splash": {
        "image": "./assets/images/Icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#f5e3d5",
        "dark": {
          "image": "./assets/images/Icon.png",
          "backgroundColor": "#1A1A1A"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Icon.png",
        "backgroundImage": "./assets/images/Icon.png",
        "monochromeImage": "./assets/images/Icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yourname.studentattendanceapp"
    },
    "web": {
      "favicon": "./assets/images/Icon.png",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f5e3d5",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
